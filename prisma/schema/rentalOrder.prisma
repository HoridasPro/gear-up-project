model RentalOrder {
  id            String      @id @default(cuid())

  customerId    String
  customer      User        @relation(fields: [customerId], references: [id])

  startDate     DateTime
  endDate       DateTime
  totalAmount   Float

  status        OrderStatus @default(PLACED)
  items         RentalItem[]
  payment       Payment?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}