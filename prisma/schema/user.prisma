model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String

  role        Role
  status      UserStatus @default(ACTIVE)

  address     String?
  image       String?

  gears       GearItem[]
  orders      RentalOrder[]
  payments    Payment[]
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}