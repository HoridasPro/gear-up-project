model User {
  id          String   @id @default(cuid())
  name        String @db.VarChar(255)
  email       String @unique
  password    String

  role        Role
  status      UserStatus @default(ACTIVE)

  address     String?
  profilePhoto  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}